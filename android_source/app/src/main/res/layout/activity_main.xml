<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUYETDEV Bank"
            android:textColor="#f8fafc"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PHIÊN BẢN V3.5 - SIÊU TRƯỜNG TỒN"
            android:textColor="#38bdf8"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:layout_marginBottom="25dp"/>

        <!-- Permission Card (Neon Border style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg_dark"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/txtPermissionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRẠNG THÁI QUYỀN: CHƯA CẤP"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnPermission"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="CẤP QUYỀN THÔNG BÁO"
                android:backgroundTint="#ec4899"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Config Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg_dark"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CẤU HÌNH WEBHOOK"
                android:textColor="#94a3b8"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ĐỊA CHỈ API (URL)"
                android:textSize="11sp"
                android:textColor="#38bdf8"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/editUrl"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="@drawable/input_bg_dark"
                android:hint="https://..."
                android:padding="16dp"
                android:textColor="#ffffff"
                android:textColorHint="#475569"
                android:textSize="15sp"
                android:textStyle="bold"
                android:inputType="textUri"
                android:layout_marginBottom="18dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOKEN BẢO MẬT"
                android:textSize="11sp"
                android:textColor="#38bdf8"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/editToken"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="@drawable/input_bg_dark"
                android:hint="••••••••••••"
                android:padding="16dp"
                android:textColor="#ffffff"
                android:textColorHint="#475569"
                android:textSize="15sp"
                android:textStyle="bold"
                android:inputType="textPassword"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DỊCH VỤ CHẠY NGẦM"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"/>

                <Switch
                    android:id="@+id/switchService"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:text="LƯU LẠI"
                    android:backgroundTint="#8b5cf6"
                    android:textColor="#ffffff"
                    android:textSize="16sp"
                    android:layout_marginEnd="6dp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnBattery"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:text="TỐI ƯU PIN"
                    android:backgroundTint="#f59e0b"
                    android:textColor="#ffffff"
                    android:textSize="16sp"
                    android:layout_marginStart="6dp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnTest"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="KIỂM TRA KẾT NỐI (TEST URL)"
                android:backgroundTint="#475569"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:layout_marginTop="12dp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Log Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg_dark"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NHẬT KÝ HOẠT ĐỘNG"
                    android:textStyle="bold"
                    android:textColor="#94a3b8"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/btnClearLogs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XÓA"
                    android:textColor="#f43f5e"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="8dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/txtLogs"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="#020617"
                android:padding="15dp"
                android:textSize="12sp"
                android:textColor="#22c55e"
                android:text="[Hệ thống v3.5 Sẵn sàng]\n"
                android:fontFamily="monospace"
                android:scrollbars="vertical"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
