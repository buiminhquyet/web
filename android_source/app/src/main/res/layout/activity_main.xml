<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8fafc">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUYETDEV Bank"
            android:textColor="#1e293b"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hệ thống tự động nạp tiền thông minh"
            android:textColor="#64748b"
            android:textSize="14sp"
            android:layout_marginBottom="25dp"/>

        <!-- Connection Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="4dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/txtPermissionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trạng thái quyền: ĐANG KIỂM TRA"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="10dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#e2e8f0"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnPermission"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="CẤP QUYỀN TRUY CẬP THÔNG BÁO"
                android:backgroundTint="#10b981"
                android:textColor="#ffffff"
                style="@style/Widget.Material3.Button"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Config Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="4dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CẤU HÌNH HỆ THỐNG"
                android:textStyle="bold"
                android:textColor="#475569"
                android:textSize="13sp"
                android:layout_marginBottom="15dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Địa chỉ Webhook (URL)"
                android:textSize="12sp"
                android:textColor="#94a3b8"
                android:layout_marginBottom="5dp"/>

            <EditText
                android:id="@+id/editUrl"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/input_bg"
                android:hint="https://yourdomain.com/api/..."
                android:padding="15dp"
                android:textSize="14sp"
                android:inputType="textUri"
                android:layout_marginBottom="15dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã bảo mật (Token)"
                android:textSize="12sp"
                android:textColor="#94a3b8"
                android:layout_marginBottom="5dp"/>

            <EditText
                android:id="@+id/editToken"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/input_bg"
                android:hint="Nhập Token bảo mật..."
                android:padding="15dp"
                android:textSize="14sp"
                android:inputType="textPassword"
                android:layout_marginBottom="20dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Trạng thái dịch vụ"
                    android:textStyle="bold"
                    android:textColor="#1e293b"/>

                <Switch
                    android:id="@+id/switchService"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gap="10dp">

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:text="LƯU LẠI"
                    android:backgroundTint="#7c3aed"
                    android:textColor="#ffffff"
                    android:layout_marginEnd="5dp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnTest"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:text="TEST URL"
                    android:backgroundTint="#64748b"
                    android:textColor="#ffffff"
                    android:layout_marginStart="5dp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Log Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NHẬT KÝ HOẠT ĐỘNG"
                    android:textStyle="bold"
                    android:textColor="#475569"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/btnClearLogs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xóa"
                    android:textColor="#f43f5e"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:padding="5dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/txtLogs"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:background="#f1f5f9"
                android:padding="12dp"
                android:textSize="11sp"
                android:textColor="#334155"
                android:text="Hệ thống đã sẵn sàng...\nChào mừng bạn đến với QUYETDEV Bank v2.0\n"
                android:fontFamily="monospace"
                android:scrollbars="vertical"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
